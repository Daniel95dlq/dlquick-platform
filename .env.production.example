# Production Environment Configuration
NEXT_PUBLIC_API_URL=https://api.dlquick.co.uk
NEXT_PUBLIC_SITE_URL=https://dlquick.co.uk
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Database
DATABASE_URL=postgresql://username:password@hostname:5432/dlquick_production

# Redis Cache
REDIS_URL=redis://cache.dlquick.co.uk:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=https://dlquick.co.uk

# Payment Processing
STRIPE_SECRET_KEY=sk_live_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@dlquick.co.uk
SMTP_PASS=your-mailgun-password

# File Storage
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-west-2
AWS_S3_BUCKET=dlquick-assets

# Analytics
GOOGLE_ANALYTICS_ID=G-...
MIXPANEL_TOKEN=...

# Error Tracking
SENTRY_DSN=https://...@sentry.io/...

# Feature Flags
NEXT_PUBLIC_ENABLE_TRACKING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHAT=true
